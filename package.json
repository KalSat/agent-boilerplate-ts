{
  "name": "agent-boilerplate-ts",
  "author": "Your Name",
  "version": "0.0.0",
  "license": "MIT",
  "description": "A modern starter template for building agentic applications using LangChain's createAgent.",
  "main": "src/main.ts",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "dev": "tsx watch src/main.ts",
    "start": "tsx src/main.ts",
    "lint": "eslint src"
  },
  "dependencies": {
    "@langchain/community": "^1.1.29",
    "@langchain/core": "^1.1.48",
    "@langchain/langgraph": "^1.3.5",
    "@langchain/anthropic": "^1.4.0",
    "@langchain/openai": "^1.4.7",
    "langchain": "^1.4.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@tsconfig/recommended": "^1.0.13",
    "@types/node": "^25.9.1",
    "@typescript-eslint/eslint-plugin": "^8.60.1",
    "@typescript-eslint/parser": "^8.60.1",
    "dotenv": "^17.4.2",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.6.0",
    "jiti": "^2.7.0",
    "prettier": "3.8.3",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.1"
  },
  "packageManager": "pnpm@11.5.1",
  "lint-staged": {
    "src/**/*.{ts,tsx}": [
      "npm run lint",
      "prettier --write --ignore-unknown"
    ]
  }
}
